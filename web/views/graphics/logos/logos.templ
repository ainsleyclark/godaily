package logos

import (
	"fmt"

	"github.com/ainsleyclark/godaily/pkg/domain/news"
)

// SourceLogo renders the brand mark for a news source at the requested pixel
// size. Falls back to a generic feed icon for unknown or logo-less sources.
templ SourceLogo(s news.Source, size int) {
	switch s {
		case news.SourceHN:
			@HackerNews(size)
		case news.SourceReddit:
			@Reddit(size)
		case news.SourceLobsters:
			@Lobsters(size)
		case news.SourceDevTo:
			@DevTo(size)
		case news.SourceGitHub, news.SourceGitHubTrending:
			@GitHub(size)
		case news.SourceYouTube:
			@YouTube(size)
		case news.SourceGoBlog, news.SourceGoRelease:
			@GoBlog(size)
		case news.SourceJetBrains:
			@JetBrains(size)
		case news.SourceMastodon:
			@Mastodon(size)
		case news.SourceLinkedIn:
			@LinkedIn(size)
		case news.SourceBluesky:
			@Bluesky(size)
		case news.SourceAwesomeGo:
			@AwesomeGo(size)
		case news.SourceMedium:
			@Medium(size)
		case news.SourceGolangBridge:
			@GolangBridge(size)
		case news.SourceMeetup:
			@Meetup(size)
		case news.SourceGoPodcast, news.SourceArdanLabs, news.SourceFallthrough:
			@Podcast(size)
		default:
			@Feed(size)
	}
}

// Background returns the brand-coloured background tint used behind the logo
// in the source pill on the homepage.
func Background(s news.Source) string {
	switch s {
	case news.SourceHN:
		return "#ff6600"
	case news.SourceReddit:
		return "#ff4500"
	case news.SourceLobsters:
		return "#ac1517"
	case news.SourceDevTo:
		return "#0a0a0a"
	case news.SourceGitHub, news.SourceGitHubTrending:
		return "#24292e"
	case news.SourceYouTube:
		return "#ff0000"
	case news.SourceGoBlog, news.SourceGoRelease:
		return "#00acd7"
	case news.SourceJetBrains:
		return "#21d789"
	case news.SourceMastodon:
		return "#6364ff"
	case news.SourceLinkedIn:
		return "#0a66c2"
	case news.SourceBluesky:
		return "#1185fe"
	case news.SourceAwesomeGo:
		return "#fbca04"
	case news.SourceMedium:
		return "#000000"
	case news.SourceGolangBridge:
		return "#00acd7"
	case news.SourceMeetup:
		return "#ff4a79"
	case news.SourceGoPodcast, news.SourceArdanLabs, news.SourceFallthrough:
		return "#7b5ea7"
	default:
		return "#2aa8d8"
	}
}

func sizeAttr(size int) string {
	return fmt.Sprintf("%d", size)
}

templ HackerNews(size int) {
	<svg width={ sizeAttr(size) } height={ sizeAttr(size) } viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
		<text x="3" y="13" font-family="Verdana, sans-serif" font-size="12" font-weight="900" fill="#ffffff">Y</text>
	</svg>
}

templ Reddit(size int) {
	<svg width={ sizeAttr(size) } height={ sizeAttr(size) } viewBox="0 0 20 20" fill="#ffffff" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
		<circle cx="10" cy="8" r="4"></circle>
		<ellipse cx="10" cy="15" rx="7" ry="4"></ellipse>
		<circle cx="15.5" cy="4.5" r="2"></circle>
	</svg>
}

templ Lobsters(size int) {
	<svg width={ sizeAttr(size) } height={ sizeAttr(size) } viewBox="0 0 20 20" fill="#ffffff" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
		<text x="2" y="15" font-family="Georgia, serif" font-size="16" font-weight="900">L</text>
	</svg>
}

templ DevTo(size int) {
	<svg width={ sizeAttr(size) } height={ sizeAttr(size) } viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
		<text x="1" y="15" font-family="Verdana, sans-serif" font-size="11" font-weight="900" fill="#ffffff">DEV</text>
	</svg>
}

