package components

import "github.com/ainsleyclark/godaily/web/views/graphics"

templ Footer() {
	<footer class="footer">
		<div class="footer__brand">
			@graphics.GopherLogo(28)
			<span>GoDaily</span>
		</div>
		<p class="footer__text">
			Built with Go and Claude. The Go Gopher was designed by
			<a class="footer__link" href="https://reneefrench.blogspot.com/">Renée French</a>,
			licensed under CC 4.0.
		</p>
	</footer>
}
