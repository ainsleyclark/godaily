PUBLIC_API_BASE_URL=https://godaily.dev

# Server-side only (never shipped to the browser). The /auth/login endpoint
# checks DASHBOARD_PASSWORD and, on success, hands back API_SECRET as the token
# the dashboard uses as a Bearer against the Go API. Leave DASHBOARD_PASSWORD
# empty in dev to allow any password.
DASHBOARD_PASSWORD=
API_SECRET=

# Dev only: where Vite's /api proxy forwards to. Override when the
# default host isn't reachable (e.g. sandboxed env, or you're running
# the Go backend locally on :8080).
# VITE_API_PROXY_TARGET=http://localhost:8080
