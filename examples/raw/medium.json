{"__typename":"CustomDomain","domain":"elsyarifx.medium.com"}},"hasSubdomain":true,"verifications":{"__typename":"VerifiedInfo","isBookAuthor":false},"imageId":"1*dXAv1M73m58zoyDFPCqxPQ@2x.jpeg","socialStats":{"__typename":"SocialStats","followerCount":273,"followingCount":81,"collectionFollowingCount":12},"bio":"Backend Enthusiast | Golang Developer | Talk about software engineering, microservices, databases, and backend best practices.","membership":{"__ref":"Membership:f673602a9082"},"allowNotes":true,"viewerEdge":{"__ref":"UserViewerEdge:userId:633e81f04453-viewerId:lo_e25c09901eac"},"twitterScreenName":""},"Membership:f673602a9082":{"__typename":"Membership","tier":"MEMBER","id":"f673602a9082"},"Paragraph:be3888bc66e5_0":{"__typename":"Paragraph","id":"be3888bc66e5_0","name":"988a","type":"H3","href":null,"layout":null,"metadata":null,"text":"Rust Is Better Than Go. I’m Still Using Go.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:be3888bc66e5_1":{"__typename":"Paragraph","id":"be3888bc66e5_1","name":"7f13","type":"H4","href":null,"layout":null,"metadata":null,"text":"Why the “best” language rarely matters in a production team of 11 engineers","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":75,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*-y6u2xGxx83Vh4rRpOSNlg.png":{"__typename":"ImageMetadata","id":"1*-y6u2xGxx83Vh4rRpOSNlg.png","originalHeight":1024,"originalWidth":1536,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:be3888bc66e5_2":{"__typename":"Paragraph","id":"be3888bc66e5_2","name":"94d8","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:1*-y6u2xGxx83Vh4rRpOSNlg.png"},"text":"AI-generated illustration","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:be3888bc66e5_3":{"__typename":"Paragraph","id":"be3888bc66e5_3","name":"7ce0","type":"P","href":null,"layout":null,"metadata":null,"text":"I ran the benchmarks on a Tuesday afternoon. Three weeks into the evaluation, we’d pushed 847 concurrent requests through both implementations. Rust’s p99 latency came in 23% lower. Memory usage was cleaner. The compiler had caught four categories of bugs our Go tests hadn’t. I stared at the numbers for longer than I should’ve admitted in a meeting. Then I closed the tab and went back to writing more Go.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:be3888bc66e5_4":{"__typename":"Paragraph","id":"be3888bc66e5_4","name":"d566","type":"P","href":null,"layout":null,"metadata":null,"text":"That was eight months ago. I still think about it occasionally — not with regret exactly, but with the specific discomfort of someone who made a reasonable decision they can’t fully defend.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:be3888bc66e5_5":{"__typename":"Paragraph","id":"be3888bc66e5_5","name":"c58a","type":"H4","href":null,"layout":null,"metadata":null,"text":"What Rust Actually Does Better","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:be3888bc66e5_6":{"__typename":"Paragraph","id":"be3888bc66e5_6","name":"7085","type":"P","href":null,"layout":null,"metadata":null,"text":"The memory model. The borrow checker. A type system with sophistication our codebase never fully demanded. Rust won on paper by a distance I couldn’t argue with. But paper doesn’t deploy services.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:be3888bc66e5_7":{"__typename":"Paragraph","id":"be3888bc66e5_7","name":"4a60","type":"P","href":null,"layout":null,"metadata":null,"text":"Three specific things stood out during the evaluation:","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:be3888bc66e5_8":{"__typename":"Paragraph","id":"be3888bc66e5_8","name":"9305","type":"P","href":null,"layout":null,"metadata":null,"text":"Memory safety without runtime overhead. Go’s garbage collector is genuinely good — better than it was in 2017, better than most teams give it credit for. But it’s still a runtime cost that appears at inopportune moments, sometimes under…","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":39,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"CollectionViewerEdge:collectionId:5517fd7b58a6-viewerId:lo_e25c09901eac":{"__typename":"CollectionViewerEdge","id":"collectionId:5517fd7b58a6-viewerId:lo_e25c09901eac","isEditor":false,"isMuting":false},"UserViewerEdge:userId:633e81f04453-viewerId:lo_e25c09901eac":{"__typename":"UserViewerEdge","id":"userId:633e81f04453-viewerId:lo_e25c09901eac","isMuting":false},"TagViewerEdge:tagSlug:programming-viewerId:lo_e25c09901eac":{"__typename":"TagViewerEdge","id":"tagSlug:programming-viewerId:lo_e25c09901eac","isMuting":false},"Tag:programming":{"__typename":"Tag","viewerEdge":{"__ref":"TagViewerEdge:tagSlug:programming-viewerId:lo_e25c09901eac"},"id":"programming","displayTitle":"Programming","normalizedTagSlug":"programming"},"TagViewerEdge:tagSlug:golang-viewerId:lo_e25c09901eac":{"__typename":"TagViewerEdge","id":"tagSlug:golang-viewerId:lo_e25c09901eac","isMuting":false},"Tag:golang":{"__typename":"Tag","viewerEdge":{"__ref":"TagViewerEdge:tagSlug:golang-viewerId:lo_e25c09901eac"},"id":"golang","displayTitle":"Golang","normalizedTagSlug":"golang"},"TagViewerEdge:tagSlug:rust-viewerId:lo_e25c09901eac":{"__ty