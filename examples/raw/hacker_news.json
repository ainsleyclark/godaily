c29yOnYyOpPPAAABm-v41YAAqjM3OTE0ODg0Njc="},"totalCount":236,"edges":[{"node":{"__typename":"LabeledEvent","__isIssueTimelineItems":"LabeledEvent","__isTimelineEvent":"LabeledEvent","databaseId":22228935936,"createdAt":"2026-01-22T23:13:56Z","actor":{"__typename":"User","login":"gopherbot","id":"MDQ6VXNlcjg1NjY5MTE=","__isActor":"User","avatarUrl":"https://avatars.githubusercontent.com/u/8566911?s=64\u0026u=be84be2341a1a28dc2ede61150f7ceaaf470b8ba\u0026v=4","profileResourcePath":"/gopherbot","name":"GopherBot"},"label":{"id":"MDU6TGFiZWwyMzY0MTk1MTI=","nameHTML":"Proposal","name":"Proposal","color":"ededed","description":null},"__isNode":"LabeledEvent","id":"LE_lADOAWBuf87lL_zwzwAAAAUs8qUA"},"cursor":"Y3Vyc29yOnYyOpPPAAABm-f8YyABqzIyMjI4OTM1OTM2"},{"node":{"__typename":"MilestonedEvent","__isIssueTimelineItems":"MilestonedEvent","__isTimelineEvent":"MilestonedEvent","databaseId":22228936516,"createdAt":"2026-01-22T23:13:57Z","actor":{"__typename":"User","login":"gopherbot","id":"MDQ6VXNlcjg1NjY5MTE=","__isActor":"User","avatarUrl":"https://avatars.githubusercontent.com/u/8566911?s=64\u0026u=be84be2341a1a28dc2ede61150f7ceaaf470b8ba\u0026v=4","profileResourcePath":"/gopherbot","name":"GopherBot"},"milestone":{"id":"MDk6TWlsZXN0b25lMTM3MzU1NQ==","url":"https://github.com/golang/go/milestone/30"},"milestoneTitle":"Proposal","__isNode":"MilestonedEvent","id":"MIE_lADOAWBuf87lL_zwzwAAAAUs8qdE"},"cursor":"Y3Vyc29yOnYyOpPPAAABm-f8ZwgBqzIyMjI4OTM2NTE2"},{"node":{"__typename":"IssueComment","__isIssueTimelineItems":"IssueComment","databaseId":3787473392,"viewerDidAuthor":false,"issue":{"author":{"__typename":"User","login":"griesemer","id":"MDQ6VXNlcjg1Mjg5NzU="},"id":"I_kwDOAWBuf87lL_zw","number":77273,"locked":false,"databaseId":3845127408},"author":{"__typename":"User","login":"mpx","avatarUrl":"https://avatars.githubusercontent.com/u/1345076?u=e4b5b659cc180e8d142916babda463b1bbf949b4\u0026v=4","profileUrl":"https://github.com/mpx","id":"MDQ6VXNlcjEzNDUwNzY=","name":"Mark Pulford"},"id":"IC_kwDOAWBuf87hwEHw","body":"Perhaps an extension could be considered (initially or later) to enable declaring specific concrete methods should exist and be available for interfaces. Eg:\n\n```golang\ntype Reader struct{ … }  \nfunc (*Reader) Read[E any]([]E) (int, error) { … }\n\n// Specify the Read method should exist for \"byte\"\nfunc (*Reader) Read[byte]([]byte) (int, error)\n\n// Now works\nvar r = io.Reader(\u0026Reader{})\n```\n\nIn some ways this is similar to declaring functions where the body is implemented elsewhere.\n\nThere may be challenges around specifying an unambiguous syntax (I haven't thought it through here). I don't have a strong opinion on the actual syntax - but it would be useful if it was possible.","bodyHTML":"\u003cp dir=\"auto\"\u003ePerhaps an extension could be considered (initially or later) to enable declaring specific concrete methods should exist and be available for interfaces. Eg:\u003c/p\u003e\n\u003cdiv class=\"highlight highlight-source-go notranslate position-relative overflow-auto\" dir=\"auto\" data-snippet-clipboard-copy-content=\"type Reader struct{ … }  \nfunc (*Reader) Read[E any]([]E) (int, error) { … }\n\n// Specify the Read method should exist for \u0026quot;byte\u0026quot;\nfunc (*Reader) Read[byte]([]byte) (int, error)\n\n// Now works\nvar r = io.Reader(\u0026amp;Reader{})\"\u003e\u003cpre class=\"notranslate\"\u003e\u003cspan class=\"pl-k\"\u003etype\u003c/span\u003e \u003cspan class=\"pl-smi\"\u003eReader\u003c/span\u003e \u003cspan class=\"pl-k\"\u003estruct\u003c/span\u003e{ … }  \n\u003cspan class=\"pl-k\"\u003efunc\u003c/span\u003e (\u003cspan class=\"pl-c1\"\u003e*\u003c/span\u003e\u003cspan class=\"pl-smi\"\u003eReader\u003c/span\u003e) \u003cspan class=\"pl-smi\"\u003eRead\u003c/span\u003e[\u003cspan class=\"pl-s1\"\u003eE\u003c/span\u003e \u003cspan class=\"pl-smi\"\u003eany\u003c/span\u003e]([]\u003cspan class=\"pl-smi\"\u003eE\u003c/span\u003e) (\u003cspan class=\"pl-s1\"\u003eint\u003c/span\u003e, \u003cspan class=\"pl-s1\"\u003eerror\u003c/span\u003e) { … }\n\n\u003cspan class=\"pl-c\"\u003e// Specify the Read method should exist for \"byte\"\u003c/span\u003e\n\u003cspan class=\"pl-k\"\u003efunc\u003c/span\u003e (\u003cspan class=\"pl-c1\"\u003e*\u003c/span\u003e\u003cspan class=\"pl-smi\"\u003eReader\u003c/span\u003e) \u003cspan class=\"pl-smi\"\u003eRead\u003c/span\u003e[\u003cspan class=\"pl-smi\"\u003ebyte\u003c/span\u003e]([]\u003cspan class=\"pl-smi\"\u003ebyte\u003c/span\u003e) (\u003cspan class=\"pl-s1\"\u003eint\u003c/span\u003e, \u003cspan class=\"pl-s1\"\u003eerror\u003c/span\u003e)\n\n\u003cspan class=\"pl-c\"\u003e// Now works\u003c/span\u003e\n\u003cspan class=\"pl-s1\"\u003evar\u003c/span\u003e \u003cspan class=\"pl-s1\"\u003er\u003c/span\u003e \u003cspan class=\"pl-c1\"\u003e=\u003c/span\u003e io.\u003cspan class=\"pl-smi\"\u003eReader\u003c/span\u003e(\u003cspan class=\"pl-c1\"\u003e\u0026amp;\u003c/span\u003e\u003cspan class=\"pl-smi\"\u003eReader\u003c/span\u003e{})\u003c/pre\u003e\u003c/div\u003e\n\u003cp dir=\"auto\"\u003eIn some ways this is similar to declaring functions where the body is implemented elsewhere.\u003c/p\u003e\n\u003cp dir=\"auto\"\u003eThere may be challenges around specifying an unambiguous syntax (I haven't thought it through here). I don't have a strong opinion on the actual syntax - but it would be useful if it was possible.\u003c/p\u003e","bodyVersion":"cb3ef5bb886d9ae9df46c70acffc3af0615ba7846e54d32d33090bbde4704089","viewerCanUpdate":false,"url":"https://github.com/golang/go/issues/77273#issuecomment-3787473392","createdAt":"2026-01-23T00:05:58Z","authorAssociation":"CONTRIBUTOR","viewerCanDelete":false,"viewerCanMinimize":false,"viewerCanUnminimize":false,"viewerCanReport":false,"viewerCanReportToMaintainer":false,"viewerCanBlockFromOrg":false,"viewerCanUnblockFromOrg":false,"viewerCanPin":false,"viewerCanUnpin":false,"viaApp":null,"isHidden":false,"minimizedReason":null,"showSpammyBadge":false,"crea