{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"version": 2,
	"buildCommand": "bash bin/build.sh",
	"installCommand": "cd web && pnpm install",
	"outputDirectory": "out",
	"trailingSlash": true,
	"cleanUrls": true,
	"crons": [
		{ "path": "/api/collect/", "schedule": "0 1 * * 1-5" },
		{ "path": "/api/send/",    "schedule": "0 8 * * 1-5" }
	],
	"functions": {
		"api/**/*.go": {
			"runtime": "@vercel/go@3.6.0",
			"maxDuration": 300
		}
	}
}
