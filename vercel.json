{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"version": 2,
	"buildCommand": "bash bin/build.sh",
	"devCommand": "mkdir -p tmp && (test -d web/node_modules || (cd web && pnpm install)) && web/node_modules/.bin/concurrently -k -n templ,air,esbuild -c blue,green,magenta 'go tool templ generate --watch --path=./web' 'go tool air -c .air.toml' 'pnpm --dir web dev'",
	"installCommand": "cd web && pnpm install",
	"outputDirectory": "out",
	"trailingSlash": true,
	"cleanUrls": true,
	"rewrites": [
		{ "source": "/healthz",                        "destination": "/api/healthz" },
		{ "source": "/api/issues/:slug",               "destination": "/api/issues/slug?slug=:slug" },
		{ "source": "/api/items/:id",                  "destination": "/api/items/id?id=:id" },
		{ "source": "/api/metrics/summary",            "destination": "/api/metrics/summary/summary" },
		{ "source": "/api/metrics/issues",             "destination": "/api/metrics/issues/issues" },
		{ "source": "/api/metrics/issues/:slug",       "destination": "/api/metrics/issues/slug/slug?slug=:slug" },
		{ "source": "/api/metrics/items",              "destination": "/api/metrics/items/items" },
		{ "source": "/api/metrics/tags",               "destination": "/api/metrics/tags/tags" },
		{ "source": "/api/metrics/sources",            "destination": "/api/metrics/sources/sources" },
		{ "source": "/api/metrics/trend",              "destination": "/api/metrics/trend/trend" },
		{ "source": "/api/metrics/subscribers",        "destination": "/api/metrics/subscribers/subscribers" }
	],
	"crons": [
		{ "path": "/api/collect/",         "schedule": "0 1 * * *"                 },
		{ "path": "/api/build/",           "schedule": "0 2 * * *"                  },
		{ "path": "/api/preview/",         "schedule": "0 6 * * 1-5"               },
		{ "path": "/api/send/",            "schedule": "0 8 * * *"                  },
		{ "path": "/api/social/",          "schedule": "0,10,20,30,40,50 11 * * *" },
		{ "path": "/api/social/metrics/",   "schedule": "0 3 * * *"                 }
	],
	"functions": {
		"api/**/*.go": {
			"runtime": "@vercel/go@3.6.0",
			"maxDuration": 300
		}
	}
}
