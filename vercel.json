{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"version": 2,
	"framework": "go",
	"installCommand": "go install github.com/a-h/templ/cmd/templ@v0.3.1001",
	"buildCommand": "bash bin/build.sh",
	"outputDirectory": "out",
	"trailingSlash": true,
	"cleanUrls": true,
	"functions": {
		"api/**/*.go": {
			"runtime": "@vercel/go@3.6.0"
		}
	}
}
