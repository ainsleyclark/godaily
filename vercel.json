{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"version": 2,
	"builds": [
		{
			"src": "package.json",
			"use": "@vercel/static-build",
			"config": { "distDir": "out" }
		},
		{
			"src": "api/*/index.go",
			"use": "@vercel/go@3.6.0"
		}
	],
	"trailingSlash": true,
	"cleanUrls": true
}
