{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"version": 2,
	"buildCommand": "bash bin/build.sh",
	"installCommand": "npm install -g pnpm@10 && cd web && pnpm install",
	"outputDirectory": "out",
	"trailingSlash": true,
	"cleanUrls": true,
	"functions": {
		"api/**/*.go": {
			"runtime": "@vercel/go@3.6.0"
		}
	}
}
