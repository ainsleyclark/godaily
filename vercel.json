{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"version": 2,
	"buildCommand": "bash bin/build.sh",
	"devCommand": "mkdir -p tmp && (test -d web/node_modules || (cd web && pnpm install)) && web/node_modules/.bin/concurrently -k -n templ,air,esbuild -c blue,green,magenta 'go tool templ generate --watch --path=./web' 'go tool air -c .air.toml' 'pnpm --dir web dev'",
	"installCommand": "cd web && pnpm install",
	"outputDirectory": "out",
	"trailingSlash": true,
	"cleanUrls": true,
	"rewrites": [
		{
			"source": "/healthz",
			"destination": "/api/index"
		},
		{
			"source": "/api/(.*)",
			"destination": "/api/index"
		}
	],
	"crons": [
		{
			"path": "/api/digest/collect/",
			"schedule": "0 1 * * *"
		},
		{
			"path": "/api/digest/build/",
			"schedule": "0 2 * * *"
		},
		{
			"path": "/api/digest/preview/",
			"schedule": "0 6 * * 1-5"
		},
		{
			"path": "/api/digest/send/",
			"schedule": "0 8 * * *"
		},
		{
			"path": "/api/social/featured/",
			"schedule": "0 11 * * *"
		},
		{
			"path": "/api/social/rotation/",
			"schedule": "0 15 * * 2,3,5"
		},
		{
			"path": "/api/social/metrics/",
			"schedule": "0 3 * * *"
		},
		{
			"path": "/api/metrics/roundup/",
			"schedule": "0 15 * * 5"
		}
	],
	"functions": {
		"api/index.go": {
			"runtime": "@vercel/go@3.6.0",
			"maxDuration": 300
		}
	}
}
